{
    "type": "object",
    "required": [
        "label",
        "is_customer",
        "customer_intent",
        "confidence_score",
        "sentiment",
        "order_number",
        "customer_name",
        "request_details"
    ],
    "properties": {
        "label": {
            "type": "string",
            "enum": [
                "Replied by Bot",
                "Notification",
                "Replied by CS"
            ]
        },
        "is_customer": {
            "type": "boolean",
            "description": "Indicates if the message is from a customer tracked by the system."
        },
        "customer_intent": {
            "type": "string",
            "enum": [
                "Order Status Inquiry",
                " Shipping Issue",
                " Complaint",
                "Refund Request",
                "Product Inquiry",
                "Change Request",
                "Change Address shipping",
                "Incorrect Information order"
            ],
            "description": "The intent of the customer's message, categorized into predefined types."
        },
        "confidence_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
        },
        "sentiment": {
            "type": "string",
            "enum": [
                "Positive",
                "Neutral",
                "Negative"
            ]
        },
        "order_number": {
            "type": [
                "string",
                "null"
            ],
            "pattern": "^#BCMC\\d{6}$",
            "description": "The order number associated with the customer's request, if applicable. Must follow the format #BCMC followed by 6 digits."
        },
        "customer_name": {
            "type": [
                "string",
                "null"
            ],
            "description": "The name of the customer, if available."
        },
        "request_details": {
            "type": "string",
            "description": "Detailed description of the customer's request or issue."
        }
    },
    "additionalProperties": false
}